# ----------------------------------------------------------------------------
# SecureOps environment variables
# Copy to `.env` and fill in. Never commit real secrets.
# ----------------------------------------------------------------------------

# Database (PostgreSQL). Payload reads DATABASE_URI; DATABASE_URL kept as alias.
# Local Docker default (see docker-compose.yml):
DATABASE_URI=postgres://secureops:secureops@localhost:5432/secureops
DATABASE_URL=postgres://secureops:secureops@localhost:5432/secureops

# Payload secret — used to sign/encrypt. Generate a long random string for prod.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public site URL (used for canonical, sitemap, OG). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Email notifications (optional). If SMTP_HOST is unset, forms still save to the
# database and the notification is skipped with a clear log message.
# ----------------------------------------------------------------------------
EMAIL_FROM=no-reply@secureops.vn
EMAIL_TO=sales@secureops.vn
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ----------------------------------------------------------------------------
# Seed admin (optional). Used by `pnpm seed` to create the first admin user.
# ----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@secureops.vn
SEED_ADMIN_PASSWORD=
